        {
          "name": "Update Journal Entry",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/journal/{{journalId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "journal",
                "{{journalId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated title\",\n  \"description\": \"Updated description text.\"\n}",
              "options": {
