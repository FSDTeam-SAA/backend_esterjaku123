    {
      "name": "Mood & Reflection (Mind / Body / Check)",
      "item": [
        {
          "name": "1. Submit Mind Step",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/mood/mind",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "mood",
                "mind"
              ]
            },
            "description": "moodScore: 1=Terrible, 2=Poor, 3=Okay, 4=Good, 5=Amazing. energyLevel/calmLevel/focusLevel are 0-100 sliders. Upserts today's reflection doc.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moodScore\": 4,\n  \"energyLevel\": 60,\n  \"calmLevel\": 80,\n  \"focusLevel\": 80,\n  \"contextTags\": [\n    \"Focused\",\n    \"Grateful\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "1b. Get AI Context-Tag Suggestions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/mood/mind/suggest-tags",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "mood",
                "mind",
                "suggest-tags"
              ]
            },
            "description": "Powers the 'AI Suggestion' chip on the Mind step. Always returns tags from the fixed CONTEXT_TAGS list, never a hallucinated word.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moodScore\": 4,\n  \"energyLevel\": 60,\n  \"calmLevel\": 80,\n  \"focusLevel\": 80\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "2. Submit Body Step",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/mood/body",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "mood",
                "body"
              ]
            },
            "description": "Requires the Mind step to be completed first (400 otherwise). Computes Sleep/Stress/Energy quality badges.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"waterGlasses\": 6,\n  \"sleepHours\": 7.75,\n  \"walkMinutes\": 20,\n  \"thoughts\": \"Feeling steady today.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "3. Get Check Step Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/mood/check",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "mood",
                "check"
              ]
            },
            "description": "Read-only recap + 3 'What if you...' predictions. Requires the Body step to be completed first."
          },
          "response": []
        },
        {
          "name": "4. Complete Reflection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/mood/complete",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "mood",
                "complete"
              ]
            },
            "description": "Idempotent — safe to call again if the network drops after the first success.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"thoughts\": \"Feeling steady today.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
