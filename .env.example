# Copy this file to .env and fill in real values. .env is git-ignored; this file is not.

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_DB_URL=mongodb://localhost:27017/ester

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# OTP (used for email verification / password reset tokens)
OTP_SECRET=change-me-otp-secret
OTP_EXPIRE=5m

# Password hashing
bcrypt_salt_round=10

# OpenAI (AI Coach replies, AI-suggested context tags, AI Insight sentence)
OPENAI_API_KEY=sk-your-openai-key
# Optional: image model for cached recommendation-card backgrounds
OPENAI_IMAGE_MODEL=gpt-image-1

# Email (SMTP) — used for OTP emails, password reset, and feedback notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Ester <no-reply@example.com>
# Where user feedback (User > Submit Feedback) gets emailed:
FEEDBACK_EMAIL=owner@example.com

# Cloudinary (avatar uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Braintree (payments)
MERCHANT_ID=your-braintree-merchant-id
PUBLIC_KEY=your-braintree-public-key
PRIVATE_KEY=your-braintree-private-key
